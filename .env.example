# ─────────────────────────────────────────────────────────────────────────────
# NIFTY + SENSEX AI Agent — Environment Variables
# Copy to .env and fill in your real values. Never commit .env!
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude API (optional — leave blank to skip AI signal explanations)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ── Pushover (iPhone/Android push notifications) ──────────────────────────────
# Sign up at https://pushover.net (free for 30 days, $5 one-time after)
# 1. Create account → copy your User Key below
# 2. Create an Application → copy its API Token below
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# ── Upstox API (optional — enables live weekly + monthly option chain data) ────
# Developer console: https://account.upstox.com/developer/apps
#
# EASIEST: paste an Analytics Access Token into UPSTOX_ACCESS_TOKEN below
# (your app → Generate Token). Read-only, market-data only, valid ~1 year — no
# daily refresh, and the KEY/SECRET/REDIRECT_URI below can stay blank.
#
# ALTERNATIVE: fill in KEY/SECRET/REDIRECT_URI and run scripts/upstox_login.py
# each morning to write a daily-expiring token. Redirect URI must be a real
# https:// URL (localhost/http are rejected by Upstox).
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://www.google.com/upstox-callback
# Analytics Access Token (~1yr) OR a daily token from scripts/upstox_login.py
UPSTOX_ACCESS_TOKEN=

# Database (SQLite by default; swap to postgresql://user:pass@host/db for prod)
DATABASE_URL=sqlite:///nifty_ai_agent.db

# Market data
NIFTY_SYMBOL=^NSEI
SENSEX_SYMBOL=^BSESN
BANKNIFTY_SYMBOL=^NSEBANK
DATA_FETCH_INTERVAL_MINUTES=5
DATA_INTERVAL=5m
HISTORICAL_DAYS=10

# Trade plan (capital-aware sizing in the plan notification)
TRADING_CAPITAL=50000
DAILY_PROFIT_TARGET=10000

# Risk
MAX_RISK_PER_TRADE_PCT=1.0
DAILY_LOSS_LIMIT_PCT=3.0
MIN_RISK_REWARD_RATIO=2.0
# Stop-loss distance as a multiple of ATR — shared by the risk and margin engines
ATR_SL_MULTIPLIER=1.5

# ── Margin (the standalone risk & margin notification) ────────────────────────
# Share of capital that may be committed as margin. Below 100 keeps a buffer so a
# single trade cannot block every rupee you have.
MAX_MARGIN_UTILISATION_PCT=100.0
# How often the risk & margin push is sent (it goes out whether or not a signal fired)
MARGIN_REPORT_INTERVAL_MINUTES=15

# Logging
LOG_LEVEL=INFO
LOG_FILE=nifty_ai_agent/logs/agent.log
