# ─────────────────────────────────────────────────────────────────────────────
# NIFTY + SENSEX AI Agent — Environment Variables
# Copy to .env and fill in your real values. Never commit .env!
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic Claude API (optional — leave blank to skip AI signal explanations)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# ── Pushover (iPhone/Android push notifications) ──────────────────────────────
# Sign up at https://pushover.net (free for 30 days, $5 one-time after)
# 1. Create account → copy your User Key below
# 2. Create an Application → copy its API Token below
PUSHOVER_USER_KEY=
PUSHOVER_API_TOKEN=

# ── Upstox API (optional — enables live weekly + monthly option chain data) ────
# Developer console: https://account.upstox.com/developer/apps
# Redirect URI must be a real https:// URL (localhost/http are rejected by Upstox)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=https://www.google.com/upstox-callback
# Filled in daily by scripts/upstox_login.py (expires ~3:30 AM IST nightly)
UPSTOX_ACCESS_TOKEN=

# Database (SQLite by default; swap to postgresql://user:pass@host/db for prod)
DATABASE_URL=sqlite:///nifty_ai_agent.db

# Market data
NIFTY_SYMBOL=^NSEI
SENSEX_SYMBOL=^BSESN
DATA_FETCH_INTERVAL_MINUTES=5
DATA_INTERVAL=5m
HISTORICAL_DAYS=10

# Risk
MAX_RISK_PER_TRADE_PCT=1.0
DAILY_LOSS_LIMIT_PCT=3.0
MIN_RISK_REWARD_RATIO=2.0

# Logging
LOG_LEVEL=INFO
LOG_FILE=nifty_ai_agent/logs/agent.log
